# Copy to .env and fill in. `docker compose` reads .env automatically.

# The domain this box serves the ingester on (DNS A/AAAA record must already
# point here before starting Caddy, so it can issue a Let's Encrypt cert).
DOMAIN=otlp.yourdomain.com

# ClickHouse — self-hosted in the "clickhouse" container. Pick a real
# password; this also becomes the "default" user's password.
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=autter_runtime

# ── Auth: choose ONE mode ──────────────────────────────────────────────────

# Mode A — self-host, static keys (simplest, no Autter account needed).
# JSON array of {key, orgId, repositoryId, scope?, allowedOrigins?}.
# Generate a key yourself, e.g.: echo "autter_rt_$(openssl rand -hex 24)"
# AUTTER_INGEST_KEYS=[{"key":"autter_rt_xxxxxxxx","orgId":"my-org","repositoryId":"my-repo"}]

# Mode B — connected to Autter Cloud for key management + issue grouping.
# AUTTER_KEY_VALIDATOR_URL=https://api.autter.dev/runtime/validate-key
# AUTTER_KEY_VALIDATOR_TOKEN=
# AUTTER_SINK_URL=https://api.autter.dev/runtime/sink
# AUTTER_SINK_TOKEN=

# Pin the ingester image tag instead of always pulling :latest (recommended
# once you're past initial setup — see the release list on GHCR).
INGESTER_TAG=latest
