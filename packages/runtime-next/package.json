{
	"name": "@autter/runtime-next",
	"version": "1.0.0",
	"description": "One-command Autter Runtime for Next.js: server OTel, browser tracker, relay route, and React error boundary",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js",
			"require": "./dist/server.cjs"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js",
			"require": "./dist/client.cjs"
		}
	},
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Autter-dev/autter-runtime.git",
		"directory": "packages/runtime-next"
	},
	"scripts": {
		"build": "tsup"
	},
	"dependencies": {
		"@autter/runtime-browser": "^1.0.0",
		"@autter/runtime-node": "^1.0.0"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"devDependencies": {
		"@types/react": "^18.3.0",
		"tsup": "^8.3.5",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"homepage": "https://github.com/Autter-dev/autter-runtime#readme",
	"bugs": "https://github.com/Autter-dev/autter-runtime/issues",
	"keywords": [
		"nextjs",
		"error-tracking",
		"telemetry",
		"opentelemetry",
		"react",
		"error-boundary"
	]
}
